# ───────────────────────────────────────────────────────────────────
# Expense Tracker — Environment Variables
# Copy this file to backend/.env (or root .env, loaded by dotenv)
# ───────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
PROJECT_NAME="Smart Expense Tracker"
ENVIRONMENT=development              # "development" | "production"
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="sqlite:///./expense_tracker.db"  # SQLite for dev; swap to Postgres for prod

# ── Authentication (Clerk) ────────────────────────────────────────
# Create an app at https://clerk.com, then paste your keys here.
# Both are required in production; in dev the app explains what's missing.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Fallback: Custom JWT auth (pre-Clerk) ─────────────────────────
# Only used if CLERK_SECRET_KEY is not set. Replace with a strong
# random key in production (minimum 32 chars).
# Generate one:  python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="dev-secret-key-change-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=60       # Session duration in minutes

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser API requests.
# In development, localhost origins are auto-allowed via regex.
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# ── Frontend (Vite) ───────────────────────────────────────────────
# The frontend reads these at build time — prefix with VITE_.
VITE_API_URL="http://localhost:8000"          # Backend URL for API calls
VITE_CLERK_PUBLISHABLE_KEY=""                 # Clerk publishable key (frontend)
